# ── Supabase ──────────────────────────────────────────────────
# Get these from: https://app.supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Dev Mode ─────────────────────────────────────────────────
# Set to "true" to bypass Supabase auth and use local mock users
VITE_DEV_MODE=true

# ── Sentry ───────────────────────────────────────────────────
# Get the DSN from: sentry.io → Settings → Projects → [project] → Client Keys (DSN)
# Leave empty to disable Sentry.
VITE_SENTRY_DSN=
